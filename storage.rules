rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Quote Wizard images — any authenticated user can read/write
    match /quoteWizards/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
