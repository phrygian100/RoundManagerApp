rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Quote Wizard images — authenticated users can read/write under their own account path
    match /quoteWizards/{accountId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == accountId;
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
